    private void addButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_addButtonActionPerformed
        
        String Name;
        String Password;
        String UserType;
        String ID;

        try {
        
        if (Nfield.getText().equals("") || Pfield.getText().equals("") || 
                (!Tfield.getText().equals("admin") && !Tfield.getText().equals("staff"))) {
            throw new IllegalArgumentException();
        }

        Name = Nfield.getText();
        UserType = Tfield.getText();
        
        boolean isValid = false; 

        do {
            
            do {
                double number = Math.random() * 100;
                String strNum = String.format("%.0f", number); 
                ID = "U" + strNum;
            } while (isIDExist(ID)); 
            
            
            do {
                Password = Pfield.getText();

                if (!isPassValid(Password)) {
                    Password = JOptionPane.showInputDialog(rootPane, "Please enter in this format: XXXXXYY X=letters Y=integers") ;
                    Pfield.setText(Password);
                }

            } while (!isPassValid(Password)); 

            isValid = !isIDExist(ID) && isPassValid(Password); 
            
        } while (!isValid);


            BufferedWriter bw = new BufferedWriter(new FileWriter("users.txt", true)); 
            bw.write(ID + " " + Name + " " + Password + " " + UserType + "\n");
            bw.close();
            DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
            String [] colheading = {"User ID", "Name", "Password", "UserType"};
            model.setColumnIdentifiers(colheading);
            String [] record = {ID, Name, Password, UserType};
            model.addRow(record);

            JOptionPane.showMessageDialog(rootPane, "User Registered Successfully");

        } catch (IllegalArgumentException Iae) {
            if (!Tfield.getText().equals("admin") && !Tfield.getText().equals("staff")) {
                JOptionPane.showMessageDialog(rootPane, "Please choose either 'admin' or 'staff'.");
            } else {
                JOptionPane.showMessageDialog(rootPane, "Please fill in all required fields.");
            }
        } catch (IOException ex) {
            JOptionPane.showMessageDialog(rootPane, "File not found.");
        }
        
    }//GEN-LAST:event_addButtonActionPerformed

    private void selButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_selButtonActionPerformed
        modButton.setEnabled(true);
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        int sRow = jTable1.getSelectedRow();
        if (sRow != -1){
            Nfield.setText(model.getValueAt(sRow, 1).toString());
            Pfield.setText(model.getValueAt(sRow, 2).toString());
            Tfield.setText(model.getValueAt(sRow, 3).toString());
            
        }
        else{
            JOptionPane.showMessageDialog(rootPane,"Please select a row!");
        }
        
        
    }//GEN-LAST:event_selButtonActionPerformed

    private void viewButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_viewButtonActionPerformed

        viewButton.setEnabled(false);
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
    try {
        BufferedReader br = new BufferedReader(new FileReader("users.txt"));
        String record = br.readLine();

        
        String[] colheading = {"User ID", "Name", "Password", "UserType"};
        model.setColumnIdentifiers(colheading);

        ArrayList<String> tokens = new ArrayList<>();

        
        while (record != null) {
            StringTokenizer token = new StringTokenizer(record, " ");

            
            while (token.hasMoreTokens()) {
                tokens.add(token.nextToken());

                
                if (tokens.size() == 4) {
                    String[] X_record = {tokens.get(0), tokens.get(1), tokens.get(2), tokens.get(3)};
                    model.addRow(X_record); 

                    tokens.clear();
                }
            }

            
            record = br.readLine();
        }

        
        br.close();

        
        if (!tokens.isEmpty()) {
            JOptionPane.showMessageDialog(rootPane, "Some lines had incomplete records with less than 4 tokens.");
        }

    } catch (FileNotFoundException ex) {
        Logger.getLogger(AdminPage.class.getName()).log(Level.SEVERE, null, ex);
    } catch (IOException ex) {
        Logger.getLogger(AdminPage.class.getName()).log(Level.SEVERE, null, ex);
    }
    }//GEN-LAST:event_viewButtonActionPerformed

    
    
    private void modButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_modButtonActionPerformed
        String selectedID;
        boolean isValid = false;
        modButton.setEnabled(false);
        ArrayList<String> arrayID = new ArrayList<>(); 
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        int sRow = jTable1.getSelectedRow();
        if (sRow != -1){
            selectedID = model.getValueAt(sRow, 0).toString();
        }
        else{
            JOptionPane.showMessageDialog(rootPane,"Please select a row!");
            return;
        }
        try{
        
        if (Nfield.getText().equals("") || Pfield.getText().equals("") || 
                    (!Tfield.getText().equals("admin") && !Tfield.getText().equals("staff"))) {
                throw new IllegalArgumentException();
        
        } 
        
        String Password = Pfield.getText();
        
        if (!isPassValid(Password)) {
            JOptionPane.showMessageDialog(rootPane, 
                "Password must be 7 characters long with the first 5 letters and last 2 numbers.");
            return;
        }
        
        
        BufferedReader br = new BufferedReader(new FileReader("users.txt"));
        String record = br.readLine();
        while (record != null){
            StringTokenizer token = new StringTokenizer(record, " ");
            
            
            if (token.countTokens()== 4){
                String fileID = token.nextToken();
                
                if (selectedID.equals(fileID)) {
                
                String updatedRecord = fileID + " " + Nfield.getText() + " " + Pfield.getText() + " " + Tfield.getText();
                 
                arrayID.add(updatedRecord); 
            } else{
                    arrayID.add(record);
                }
            
            }
            record = br.readLine();
        }
        br.close();
        BufferedWriter bw = new BufferedWriter(new FileWriter("users.txt"));
        for (String updatedRecord : arrayID) {
            bw.write(updatedRecord);
            bw.newLine(); 
        }
        bw.close(); 
       
        if (sRow != -1){
            model.setValueAt(Nfield.getText(), sRow, 1);
            model.setValueAt(Pfield.getText(), sRow, 2);
            model.setValueAt(Tfield.getText(), sRow, 3);
            JOptionPane.showMessageDialog(rootPane, "Record updated successfully!");
        }
        
        
    }//GEN-LAST:event_modButtonActionPerformed
    catch (IllegalArgumentException Iae) {
            if (!Tfield.getText().equals("admin") && !Tfield.getText().equals("staff")) {
                JOptionPane.showMessageDialog(rootPane, "Please choose either 'admin' or 'staff'.");
            } else {
                JOptionPane.showMessageDialog(rootPane, "Please fill in all required fields.");
            }
        } catch (FileNotFoundException ex) {
            Logger.getLogger(AdminPage.class.getName()).log(Level.SEVERE, null, ex);
        } catch (IOException ex) {
            Logger.getLogger(AdminPage.class.getName()).log(Level.SEVERE, null, ex);
        }
    }
    private void delButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_delButtonActionPerformed
            
        ArrayList<String> arrayID = new ArrayList<>();
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        String selectedID;

        try {
            int sRow = jTable1.getSelectedRow();
            if (sRow != -1) {
                selectedID = model.getValueAt(sRow, 0).toString();
                model.removeRow(sRow);  
            } else {
                JOptionPane.showMessageDialog(rootPane, "Please select a row");
                return;  
            }

            BufferedReader br = new BufferedReader(new FileReader("users.txt"));
            String record = br.readLine();

            
            while (record != null) {
                StringTokenizer token = new StringTokenizer(record, " ");

                if (token.countTokens() == 4) {
                    String fileID = token.nextToken();  

                    
                    if (!selectedID.equals(fileID)) {
                        arrayID.add(record);  
                    }
                }
                record = br.readLine();  
            }
            br.close();

           
            BufferedWriter bw = new BufferedWriter(new FileWriter("users.txt"));
            for (String updatedRecord : arrayID) {
                bw.write(updatedRecord);  
                bw.newLine();  
            }
            bw.close();

            JOptionPane.showMessageDialog(rootPane, "Record deleted successfully!");

        } catch (IOException ex) {
            Logger.getLogger(AdminPage.class.getName()).log(Level.SEVERE, null, ex);
        }
        
    }//GEN-LAST:event_delButtonActionPerformed

    private void nextButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_nextButtonActionPerformed
        AdminPPEInventory page = new AdminPPEInventory();
        page.setVisible(true);
        this.setVisible(false);
        File ppeFile = new File("ppe.txt");
        if (ppeFile.exists()){
            JOptionPane.showMessageDialog(rootPane,"PPE Inventory file already exists");
        } else {
            try {
                    initializePPEFile(ppeFile);
                    JOptionPane.showMessageDialog(null, "PPE inventory initialized successfully.");
                } catch (IOException ex) {
                    JOptionPane.showMessageDialog(null, "Error initializing PPE inventory: " + ex.getMessage());
                }
            
        }
    }//GEN-LAST:event_nextButtonActionPerformed

