        // TODO add your handling code here:
    }//GEN-LAST:event_PfieldActionPerformed
        
    private void initializePPEFile(File ppeFile) throws IOException {
            if (ppeFile.createNewFile()) {
                
                BufferedWriter bw = new BufferedWriter(new FileWriter(ppeFile));

                
                bw.write("HC 100 Scode\n");  
                bw.write("FS 100 Scode\n");  
                bw.write("MS 100 Scode\n");  
                bw.write("GL 100 Scode\n");  
                bw.write("GW 100 Scode\n");  
                bw.write("SC 100 Scode\n");  

                bw.close();  
            } else {
                throw new IOException("Failed to create PPE inventory file.");
            }
        }

    private boolean isIDExist(String newID) throws IOException {
    BufferedReader br = new BufferedReader(new FileReader("users.txt"));
    String record;
    
    
    while ((record = br.readLine()) != null) {
        StringTokenizer token = new StringTokenizer(record, " ");
        String existingID = token.nextToken(); 
        
        if (existingID.equals(newID)) {
            br.close(); 
            return true; 
        }
    }
    
    br.close(); 
    return false; 
    }     
    
    private boolean isPassValid(String newPass) {
    
    return newPass.length() == 7 && newPass.matches("^[a-zA-Z]{5}\\d{2}$");
}
    
    
    
