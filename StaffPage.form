    private void SubmitButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_SubmitButtonActionPerformed
        // Get the selected values from ComboBox and TextFields
        String selectedWhoID = WhoID.getSelectedItem().toString();  // ComboBox value (Supplier ID or Hospital ID)
        String whoIDValue = sH.getText().trim();  // TextField for Supplier/Hospital ID
        String productIDValue = (String) ProductID.getSelectedItem();  // ComboBox value for Product ID
        String quantityValue = Quantity.getText().trim();  // TextField for Quantity

        // Validate if any fields are empty
        if (whoIDValue.isEmpty() || productIDValue.equals("Select Product") || quantityValue.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Please enter all details", "Error", JOptionPane.ERROR_MESSAGE);
            return;
        }

        // Validate quantity input
        int quantity;
        try {
            quantity = Integer.parseInt(quantityValue);  // Parse quantity as an integer
            if (quantity <= 0) {
                JOptionPane.showMessageDialog(this, "Quantity must be greater than 0", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }
        } catch (NumberFormatException e) {
            JOptionPane.showMessageDialog(this, "Invalid quantity entered", "Error", JOptionPane.ERROR_MESSAGE);
            return;
        }

        // Step 1: Check stock in PPE.txt first, do not update anything if stock is insufficient
        File ppeFile = new File("ppe.txt");
        StringBuilder updatedPPEContent = new StringBuilder();
        boolean foundInPPE = false;
        boolean sufficientStock = true;  // This flag will indicate if there is sufficient stock

        try (BufferedReader br = new BufferedReader(new FileReader(ppeFile))) {
            String record;

            while ((record = br.readLine()) != null) {
                String[] tokens = record.split(" ");  // Assuming the format is: ProductID Quantity SupplierID

                if (tokens[0].equals(productIDValue)) {  // Check if the product ID matches
                    foundInPPE = true;
                    int currentStock = Integer.parseInt(tokens[1]);  // Get the current stock quantity

                    // Check if it's hospital distribution and whether there is sufficient stock
                    if (selectedWhoID.equals("Hospital ID")) {
                        if (currentStock < quantity) {
                            // Insufficient stock, stop the operation
                            JOptionPane.showMessageDialog(this, "Insufficient stock! Available quantity: " + currentStock, "Error", JOptionPane.ERROR_MESSAGE);
                            sufficientStock = false;  // Set the flag to false, insufficient stock
                            return;  // Stop execution here if stock is insufficient
                        } else {
                            currentStock -= quantity;  // Subtract quantity for hospital
                        }
                    } else {
                        // For suppliers, just add the quantity
                        currentStock += quantity;
                    }

                    // Prepare updated PPE line
                    updatedPPEContent.append(tokens[0]).append(" ")
                            .append(currentStock).append(" ")
                            .append(tokens[2]).append("\n");
                } else {
                    // Keep the record unchanged if it's a different product
                    updatedPPEContent.append(record).append("\n");
                }
            }
        } catch (IOException e) {
            JOptionPane.showMessageDialog(this, "Error reading the file: " + e.getMessage(), "Error", JOptionPane.ERROR_MESSAGE);
            return;
        }

        // If stock is insufficient, do not proceed
        if (!sufficientStock) {
            return;  // Exit if insufficient stock was detected earlier
        }

        // Step 2: Proceed with updating hospital.txt or suppliers.txt if stock is sufficient
        File inputFile = new File(selectedWhoID.equals("Hospital ID") ? "hospital.txt" : "suppliers.txt");
        boolean foundEntity = false;  // Track if hospital or supplier is found
        boolean foundProduct = false;  // Track if product is found for the entity (hospital or supplier)
        StringBuilder updatedFileContent = new StringBuilder();

        try (BufferedReader br = new BufferedReader(new FileReader(inputFile))) {
            String record;
            while ((record = br.readLine()) != null) {
                StringTokenizer token = new StringTokenizer(record, " ");
                if (token.countTokens() == 3) {
                    String fileEntityID = token.nextToken().trim();  // This will be either Supplier ID or Hospital ID
                    String fileProductID = token.nextToken().trim();
                    int fileQuantity = Integer.parseInt(token.nextToken().trim());

                    if (fileEntityID.equals(whoIDValue)) {
                        foundEntity = true;
                        if (fileProductID.equals(productIDValue)) {
                            foundProduct = true;
                            // Update the quantity if the product ID matches
                            if (selectedWhoID.equals("Hospital ID")) {
                                fileQuantity += quantity;  // Subtract for hospital
                            } else {
                                fileQuantity += quantity;  // Add for supplier
                            }
                            updatedFileContent.append(fileEntityID).append(" ")
                                    .append(fileProductID).append(" ")
                                    .append(fileQuantity).append("\n");
                        } else {
                            updatedFileContent.append(record).append("\n");
                        }
                    } else {
                        updatedFileContent.append(record).append("\n");
                    }
                }
            }
        } catch (IOException e) {
            e.printStackTrace();
        }

        if (!foundEntity) {
            JOptionPane.showMessageDialog(this, "No matching " + selectedWhoID + " ID found", "Error", JOptionPane.ERROR_MESSAGE);
            return;  // Exit the function, preventing any updates
        }

        if (!foundProduct) {
            updatedFileContent.append(whoIDValue).append(" ")
                    .append(productIDValue).append(" ")
                    .append(quantity).append("\n");
        }

        // Step 3: Write the updated content back to hospital.txt or suppliers.txt
        try (BufferedWriter bw = new BufferedWriter(new FileWriter(inputFile))) {
            bw.write(updatedFileContent.toString());
        } catch (IOException e) {
            e.printStackTrace();
        }

        // Step 4: Write the updated content back to PPE.txt
        try (BufferedWriter bw = new BufferedWriter(new FileWriter(ppeFile))) {
            bw.write(updatedPPEContent.toString());
        } catch (IOException e) {
            JOptionPane.showMessageDialog(this, "Error writing to the file: " + e.getMessage(), "Error", JOptionPane.ERROR_MESSAGE);
        }

        // Step 9: Update JTable2 with the new quantity
        DefaultTableModel model = (DefaultTableModel) jTable2.getModel();
        boolean foundInTable = false;

        // Loop through JTable2 rows to find the matching Product ID
        for (int i = 0; i < model.getRowCount(); i++) {
            String tableProductID = model.getValueAt(i, 1).toString();  // Assuming Product ID is in the second column

            if (tableProductID.equals(productIDValue)) {
                foundInTable = true;
                int currentStock = Integer.parseInt(model.getValueAt(i, 2).toString());  // Get the current stock quantity

                // Update the quantity in JTable2 (same logic as above for sum or subtract)
                if (selectedWhoID.equals("Hospital ID")) {
                    currentStock -= quantity;  // Subtract quantity for hospital
                } else {
                    currentStock += quantity;  // Add quantity for supplier
                }

                // Update the quantity in JTable2
                model.setValueAt(currentStock, i, 2);  // Assuming Quantity is in the third column
                break;
            }
        }

        // Show success message after update
        JOptionPane.showMessageDialog(this, "Product ID and Quantity updated successfully!");

        // Step 10: Record the transaction in transaction.txt (you can keep this logic if needed)
        File transactionFile = new File("transactions.txt");
        StringBuilder transactionFileContent = new StringBuilder();
        boolean transactionFound = false;

// Determine whether to log 'Received' or 'Distributed'
        String actionType = selectedWhoID.equals("Supplier ID") ? "Received" : "Distributed";

        try (BufferedReader br = new BufferedReader(new FileReader(transactionFile))) {
            String record;

            // Read through the existing file without changing any existing data
            while ((record = br.readLine()) != null) {
                transactionFileContent.append(record).append("\n");
            }

        } catch (IOException e) {
            e.printStackTrace();
        }

// Add a new row for every update (regardless of previous entries)
        LocalDateTime now = LocalDateTime.now();
        DateTimeFormatter formatter = DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss");
        String formattedDateTime = now.format(formatter);

// Create a new line for the new transaction
        transactionFileContent.append(actionType).append(" ").append(whoIDValue).append(" ")
                .append(productIDValue).append(" ").append(quantity).append(" ")
                .append(formattedDateTime).append("\n");

// Write the updated transactions back to transactions.txt (overwrite mode)
        try (BufferedWriter bw = new BufferedWriter(new FileWriter(transactionFile, false))) {
            bw.write(transactionFileContent.toString());
        } catch (IOException e) {
            e.printStackTrace();
        }

        autoupdateIntoTable();

        // Clear input fields after submission
        sH.setText("");
        Quantity.setText("");
        ProductID.setSelectedItem("Select Product");
        WhoID.setSelectedItem("Supplier ID");
    }//GEN-LAST:event_SubmitButtonActionPerformed

    private void autoupdateIntoTable() {
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        model.setRowCount(0);  // Clear the table before adding new rows

        // Read the transaction.txt file
        try (BufferedReader br = new BufferedReader(new FileReader("transactions.txt"))) {
            String record;

            // Process each line from the file
            while ((record = br.readLine()) != null) {
                ArrayList<String> tokens = new ArrayList<>();
                StringTokenizer token = new StringTokenizer(record, " ");

                // Tokenize and store the tokens in the list
                while (token.hasMoreTokens()) {
                    tokens.add(token.nextToken());
                }

                // If 6 tokens are found, add the row to the table
                if (tokens.size() == 6) {
                    String[] X_record = {tokens.get(0), tokens.get(1), tokens.get(2), tokens.get(3), tokens.get(4), tokens.get(5)};
                    model.addRow(X_record);
                }
            }

        } catch (FileNotFoundException e) {
            JOptionPane.showMessageDialog(this, "File not found: transaction.txt", "Error", JOptionPane.ERROR_MESSAGE);
        } catch (IOException e) {
            JOptionPane.showMessageDialog(this, "Error reading the file", "Error", JOptionPane.ERROR_MESSAGE);
        }
    }

    private void ViewButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_ViewButtonActionPerformed
        // Clear the existing table data
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        model.setRowCount(0);  // Clear existing rows before adding new data

        // Column headers
        String[] colheading = {"Transaction", "ID", "Product ID", "Quantity", "Date", "Time"};
        model.setColumnIdentifiers(colheading);

        // Read the transaction.txt file
        try (BufferedReader br = new BufferedReader(new FileReader("transactions.txt"))) {
            String record;

            // Process each line from the file
            while ((record = br.readLine()) != null) {
                ArrayList<String> tokens = new ArrayList<>(); // Re-initialize tokens for each line
                StringTokenizer token = new StringTokenizer(record, " ");

                // Tokenize and store the tokens in the list
                while (token.hasMoreTokens()) {
                    tokens.add(token.nextToken());
                }

                // If 6 tokens are found, add the row to the table
                if (tokens.size() == 6) {
                    String[] X_record = {tokens.get(0), tokens.get(1), tokens.get(2), tokens.get(3), tokens.get(4), tokens.get(5)};
                    model.addRow(X_record);
                }
            }

        } catch (FileNotFoundException e) {
            JOptionPane.showMessageDialog(this, "File not found: transaction.txt", "Error", JOptionPane.ERROR_MESSAGE);
        } catch (IOException e) {
            JOptionPane.showMessageDialog(this, "Error reading the file", "Error", JOptionPane.ERROR_MESSAGE);
        }
    }//GEN-LAST:event_ViewButtonActionPerformed

    private void DeleteActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_DeleteActionPerformed
        // Get the table model
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();

        // Check if a single row is selected
        if (jTable1.getSelectedRowCount() == 1) {
            // Get data from the selected row (assuming relevant data is in columns 0, 1, 2, 3 for Transaction, ID, Product ID, and Quantity)
            String transactionType = model.getValueAt(jTable1.getSelectedRow(), 0).toString(); // Transaction type (Received/Distributed)
            String id = model.getValueAt(jTable1.getSelectedRow(), 1).toString();             // Supplier/Hospital ID
            String productID = model.getValueAt(jTable1.getSelectedRow(), 2).toString();      // Product ID
            int quantity = Integer.parseInt(model.getValueAt(jTable1.getSelectedRow(), 3).toString());  // Quantity

            // Remove the row from the table
            model.removeRow(jTable1.getSelectedRow());

            // Update transaction.txt file by removing the corresponding row
            File transactionFile = new File("transactions.txt");
            StringBuilder updatedFileContent = new StringBuilder();

            try (BufferedReader br = new BufferedReader(new FileReader(transactionFile))) {
                String record;

                // Read through the file and copy everything except the deleted row
                while ((record = br.readLine()) != null) {
                    StringTokenizer token = new StringTokenizer(record, " ");

                    if (token.countTokens() == 6) { // Ensure it has the correct number of tokens
                        String fileTransactionType = token.nextToken();
                        String fileID = token.nextToken();
                        String fileProductID = token.nextToken();
                        String fileQuantity = token.nextToken();

                        // Only append rows that don't match the deleted row
                        if (!fileTransactionType.equals(transactionType) || !fileID.equals(id) || !fileProductID.equals(productID)) {
                            updatedFileContent.append(record).append("\n");
                        }
                    }
                }
            } catch (IOException e) {
                e.printStackTrace();
            }

            // Write the updated content back to transactions.txt
            try (BufferedWriter bw = new BufferedWriter(new FileWriter(transactionFile))) {
                bw.write(updatedFileContent.toString());
            } catch (IOException e) {
                e.printStackTrace();
            }

            // Step 2: Adjust the quantity in hospital.txt or suppliers.txt
            String fileName = id.startsWith("H") ? "hospital.txt" : "suppliers.txt";  // Determine file based on ID (Hospital or Supplier)
            File inputFile = new File(fileName);
            StringBuilder updatedEntityFileContent = new StringBuilder();

            try (BufferedReader br = new BufferedReader(new FileReader(inputFile))) {
                String record;
                while ((record = br.readLine()) != null) {
                    StringTokenizer token = new StringTokenizer(record, " ");

                    if (token.countTokens() == 3) {  // Assuming format: ID ProductID Quantity
                        String fileEntityID = token.nextToken();
                        String fileProductID = token.nextToken();
                        int fileQuantity = Integer.parseInt(token.nextToken());

                        if (fileEntityID.equals(id) && fileProductID.equals(productID)) {
                            // Adjust the quantity based on the transaction type
                            if (transactionType.equals("Received")) {
                                // If it was a "Received" transaction, subtract the quantity (reverting the original action)
                                fileQuantity -= quantity;
                            } else if (transactionType.equals("Distributed")) {
                                // If it was a "Distributed" transaction, add the quantity back
                                fileQuantity += quantity;
                            }
                        }
                        // Append the updated record to the new content
                        updatedEntityFileContent.append(fileEntityID).append(" ")
                                .append(fileProductID).append(" ")
                                .append(fileQuantity).append("\n");
                    }
                }
            } catch (IOException e) {
                e.printStackTrace();
            }

            // Write the updated content back to hospital.txt or suppliers.txt
            try (BufferedWriter bw = new BufferedWriter(new FileWriter(inputFile))) {
                bw.write(updatedEntityFileContent.toString());
            } catch (IOException e) {
                e.printStackTrace();
            }

            // Step 3: Adjust the quantity in ppe.txt
            File ppeFile = new File("ppe.txt");
            StringBuilder updatedPPEFileContent = new StringBuilder();

            try (BufferedReader br = new BufferedReader(new FileReader(ppeFile))) {
                String record;
                while ((record = br.readLine()) != null) {
                    StringTokenizer token = new StringTokenizer(record, " ");

                    if (token.countTokens() == 3) {  // Assuming format: ProductID Quantity SupplierID
                        String fileProductID = token.nextToken();
                        int fileQuantity = Integer.parseInt(token.nextToken());
                        String supplierID = token.nextToken();

                        if (fileProductID.equals(productID)) {
                            // Adjust the quantity based on the transaction type
                            if (transactionType.equals("Received")) {
                                fileQuantity -= quantity;  // Subtract the received quantity from the stock
                            } else if (transactionType.equals("Distributed")) {
                                fileQuantity -= quantity;  // Add the distributed quantity back to the stock
                            }
                        }

                        // Append the updated record to the new content
                        updatedPPEFileContent.append(fileProductID).append(" ")
                                .append(fileQuantity).append(" ")
                                .append(supplierID).append("\n");
                    }
                }
            } catch (IOException e) {
                e.printStackTrace();
            }

            // Write the updated content back to ppe.txt
            try (BufferedWriter bw = new BufferedWriter(new FileWriter(ppeFile))) {
                bw.write(updatedPPEFileContent.toString());
            } catch (IOException e) {
                e.printStackTrace();
            }

            // Step 4: Update JTable2 (ppe stock table) directly
            DefaultTableModel ppeModel = (DefaultTableModel) jTable2.getModel();
            for (int i = 0; i < ppeModel.getRowCount(); i++) {
                String tableProductID = ppeModel.getValueAt(i, 1).toString();  // Assuming Product ID is in the second column

                if (tableProductID.equals(productID)) {
                    int currentStock = Integer.parseInt(ppeModel.getValueAt(i, 2).toString());  // Get the current stock

                    // Adjust the quantity based on the transaction type
                    if (transactionType.equals("Received")) {
                        currentStock -= quantity;  // Subtract the received quantity
                    } else if (transactionType.equals("Distributed")) {
                        currentStock += quantity;  // Add back the distributed quantity
                    }

                    // Update the stock in the JTable2
                    ppeModel.setValueAt(currentStock, i, 2);  // Update the quantity column
                    break;  // Exit the loop once the product is found
                }
            }

        } else {
            // If no rows or multiple rows are selected
            if (model.getRowCount() == 0) {
                JOptionPane.showMessageDialog(this, "Table is Empty.");
            } else {
                JOptionPane.showMessageDialog(this, "Please select a single row to delete.");
            }
        }

        // Clear input fields after submission
        sH.setText("");
        Quantity.setText("");
        ProductID.setSelectedItem("Select Product");
        WhoID.setSelectedItem("Supplier ID");
    }//GEN-LAST:event_DeleteActionPerformed

