    private void Edit2ActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_Edit2ActionPerformed
        // TODO add your handling code here:
        // Get the table model
        DefaultTableModel model = (DefaultTableModel) jTable2.getModel();

        // Check if a row is selected
        int selectedRow = jTable2.getSelectedRow();

        if (selectedRow != -1) { // Ensure a row is selected
            // Get the new value from the ForTable2 text field
            String number = ForTable2.getText();

            // Validate the new quantity is a valid number
            try {
                int quantity = Integer.parseInt(number);
                if (quantity < 0) {
                    JOptionPane.showMessageDialog(this, "Quantity must be greater than or equal to 0", "Error", JOptionPane.ERROR_MESSAGE);
                    return;
                }
            } catch (NumberFormatException e) {
                JOptionPane.showMessageDialog(this, "Invalid quantity entered", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }

            // Update the value in the table at the selected row and column 2 (Quantity column)
            model.setValueAt(number, selectedRow, 2);

            // After updating the table, update only the quantity in ppe.txt
            String productCode = model.getValueAt(selectedRow, 1).toString(); // Get the product code (column 1)
            updateQuantityInFile(productCode, number); // Update the file

            // Show success message
            JOptionPane.showMessageDialog(this, "Update Successfully!");
        } else {
            // If no row is selected, show an error message
            if (jTable2.getRowCount() == 0) {
                JOptionPane.showMessageDialog(this, "Table is empty!");
            } else {
                JOptionPane.showMessageDialog(this, "Please select a row to edit!");
            }
        }

        ForTable2.setText(""); // Clear the input field after editing
    }//GEN-LAST:event_Edit2ActionPerformed

// Method to update only the quantity in ppe.txt
    private void updateQuantityInFile(String productCode, String newQuantity) {
        File inputFile = new File("ppe.txt");
        StringBuilder updatedFileContent = new StringBuilder();

        try (BufferedReader br = new BufferedReader(new FileReader(inputFile))) {
            String record;

            // Loop through each line in ppe.txt
            while ((record = br.readLine()) != null) {
                String[] tokens = record.split(" ");

                // If the first token matches the product code, update the quantity
                if (tokens[0].equals(productCode)) {
                    tokens[1] = newQuantity; // Update the quantity (assuming it's in the second position)
                }

                // Rebuild the line and append to the file content
                updatedFileContent.append(String.join(" ", tokens)).append("\n");
            }

        } catch (IOException e) {
            JOptionPane.showMessageDialog(this, "Error reading the file: " + e.getMessage(), "Error", JOptionPane.ERROR_MESSAGE);
        }

        // Write the updated content back to ppe.txt
        try (BufferedWriter bw = new BufferedWriter(new FileWriter(inputFile))) {
            bw.write(updatedFileContent.toString());
        } catch (IOException e) {
            JOptionPane.showMessageDialog(this, "Error writing to the file: " + e.getMessage(), "Error", JOptionPane.ERROR_MESSAGE);
        }
    }

    private void jTable2MouseClicked(java.awt.event.MouseEvent evt) {//GEN-FIRST:event_jTable2MouseClicked
        // Get the model from jTable2
        DefaultTableModel model = (DefaultTableModel) jTable2.getModel();

        // Get the value from the selected row (column 2 in this case)
        String tblQuantity = model.getValueAt(jTable2.getSelectedRow(), 2).toString();

        // Assuming ForTable2 is a JTextField, set the value into it
        ForTable2.setText(tblQuantity);
    }//GEN-LAST:event_jTable2MouseClicked

    private void View2ActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_View2ActionPerformed
        // TODO add your handling code here:
        // Get the model from jTable2
        DefaultTableModel model = (DefaultTableModel) jTable2.getModel();

        // Clear existing data in jTable2
        model.setRowCount(0);

        // Set column headers (Product Name, Product Code, Quantity in Stock)
        String[] colheading = {"Product Name", "Product Code", "Quantity in Stock"};
        model.setColumnIdentifiers(colheading);

        // Predefined list of product names (6 products)
        String[] productNames = {"Head Cover", "Face Shield", "Mask", "Gloves", "Gown", "Shoe Covers"};

        // Read data from ppe.txt and populate the table with product name, product code, and quantity
        try (BufferedReader br = new BufferedReader(new FileReader("ppe.txt"))) {
            String record;
            int rowIndex = 0;

            // Read each line from the file
            while ((record = br.readLine()) != null && rowIndex < productNames.length) {
                String[] rowData = record.split(" ");  // Assuming space-separated data in ppe.txt
                if (rowData.length >= 3) {  // Ensure there are at least 3 elements (Product Code, Quantity, Supplier Code)
                    // Add row with product name, product code, and quantity
                    String[] tableRow = {productNames[rowIndex], rowData[0], rowData[1]};  // Product Name, Product Code, and Quantity
                    model.addRow(tableRow);
                    rowIndex++;  // Increment the index for the product names
                }
            }

        } catch (IOException e) {
            JOptionPane.showMessageDialog(null, "Error reading file: " + e.getMessage(), "Error", JOptionPane.ERROR_MESSAGE);
        }
    }//GEN-LAST:event_View2ActionPerformed

