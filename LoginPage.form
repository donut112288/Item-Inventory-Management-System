    private void createSupplierActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_createSupplierActionPerformed
    createSupplier.setEnabled(false);
    selButton.setEnabled(true);
    ArrayList<String> supplierCodesList = new ArrayList<>();

    // Try to create as many suppliers as possible
    try {
        // Assuming Supplier.MAX_SUPCOUNT is the maximum number of suppliers you want to create
        while (supplierCodesList.size() < Supplier.MAX_SUPCOUNT) { 
            Supplier newSupplier = new Supplier();  // Create a new Supplier object
            
            // Assuming getSupplierCode() returns a unique supplier code
            String supplierCode = newSupplier.getSupplierCode(); 
            
            // Only add the code if it's unique
            if (!supplierCodesList.contains(supplierCode)) {
                supplierCodesList.add(supplierCode); // Add to the list
            }
        }

        // Set the supplier codes to the codeField as a comma-separated string
        codeField.setText(String.join(",", supplierCodesList));
        
        // Optionally, show a success message
        JOptionPane.showMessageDialog(rootPane, "All available supplier codes have been created and set.");
        
    } catch (IllegalStateException e) {
        // Handle the case where no more suppliers can be created
        JOptionPane.showMessageDialog(rootPane, e.getMessage());
    }
    
    
    }//GEN-LAST:event_createSupplierActionPerformed

    private void selButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_selButtonActionPerformed
        
        
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        int sRow = jTable1.getSelectedRow();
        if (sRow != -1){
            takenCodefield.setText(model.getValueAt(sRow, 2).toString());
            modButton.setEnabled(true);
        }
        else{
            JOptionPane.showMessageDialog(rootPane,"Please select a row!");
        }
        
        
    }//GEN-LAST:event_selButtonActionPerformed

    private void modButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_modButtonActionPerformed
        saveButton.setEnabled(true);
        modButton.setEnabled(false);
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        int sRow = jTable1.getSelectedRow(); // Get the selected row

        // Step 1: Retrieve supplier codes from codeField
        ArrayList<String> supplierCodesList = new ArrayList<>();
        StringTokenizer token = new StringTokenizer(codeField.getText(), ",");

        // Populate the supplierCodesList
        while (token.hasMoreTokens()) {
            String code = token.nextToken().trim(); // Get each code and trim whitespace
            if (!supplierCodesList.contains(code)) {
                supplierCodesList.add(code); // Add to the list if not already present
            }
        }

        // Step 2: Get the new supply code from takenCodeField
        String newSupplyCode = takenCodefield.getText().trim(); // Get user input and trim whitespace

        // Input validation for the new supply code format (SUPX)
        if (!newSupplyCode.matches("SUP\\d")) { // Checks for "SUP" followed by a single digit
            JOptionPane.showMessageDialog(rootPane, "Please enter a valid supply code in the format: SUPX (X = digit).");
            return; // Prevent further execution
        }

        // Step 3: Check if the new supply code is in the supplierCodesList
        if (supplierCodesList.contains(newSupplyCode)) {
            // Step 4: Modify the selected row
            if (sRow >= 0) { // Check if a row is selected
                model.setValueAt(newSupplyCode, sRow, 2); // Change the supply code (assuming it's in the 3rd column, index 2)
                JOptionPane.showMessageDialog(rootPane, "Supply code updated successfully.");
                takenCodefield.setText(""); // Clear the input field after processing


            } else {
                JOptionPane.showMessageDialog(rootPane, "Please select a row to modify.");
            }
        } else {
            // Step 5: Prevent further execution
            JOptionPane.showMessageDialog(rootPane, "The entered supply code is not valid. Please enter a valid code.");
        }


    }//GEN-LAST:event_modButtonActionPerformed

private boolean isScodePresent(DefaultTableModel model) {
    for (int i = 0; i < model.getRowCount(); i++) {
        String supplyCode = (String) model.getValueAt(i, 2); // Assuming supply code is in the 3rd column
        if (supplyCode.equals("Scode")) {
            return true; // "Scode" found
        }
    }
    return false; // No "Scode" found
}
    
    
    // Method to check if all supplier codes from the list are used at least once
private boolean areAllSupplierCodesUsed(DefaultTableModel model, ArrayList<String> supplierCodesList) {
    for (String code : supplierCodesList) {
        boolean found = false;
        for (int i = 0; i < model.getRowCount(); i++) {
            String supplyCode = (String) model.getValueAt(i, 2); // Assuming supply code is in the 3rd column
            if (supplyCode.equals(code)) {
                found = true; // Supplier code found in the table
                break; // No need to check further for this code
            }
        }
        if (!found) {
            return false; // At least one supplier code was not found
        }
    }
    return true; // All supplier codes are used at least once
}

// Method to proceed to the next step
private void proceedToNextStep() {
    // Implement your logic for the next step here
    JOptionPane.showMessageDialog(rootPane, "All checks passed. Proceeding to the next step.");
}
    
    
    
    
    
    
    
    
    private void saveButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_saveButtonActionPerformed
        saveButton.setEnabled(false);
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();

    // Step 1: Check if "Scode" is present
    if (isScodePresent(model)) {
        JOptionPane.showMessageDialog(rootPane, "Please ensure there are no 'Scode' entries before saving.");
        return; // Prevent further execution
    }

    // Step 2: Retrieve supplier codes from codeField
    ArrayList<String> supplierCodesList = new ArrayList<>();
    StringTokenizer token = new StringTokenizer(codeField.getText(), ",");

    // Populate the supplierCodesList
    while (token.hasMoreTokens()) {
        String code = token.nextToken().trim(); // Get each code and trim whitespace
        if (!supplierCodesList.contains(code)) {
            supplierCodesList.add(code); // Add to the list if not already present
        }
    }

    // Step 3: Check if all supplier codes are used
    if (!areAllSupplierCodesUsed(model, supplierCodesList)) {
        JOptionPane.showMessageDialog(rootPane, "Please ensure all supplier codes are used before saving.");
        return; // Prevent further execution
    }

    // Step 4: Overwrite ppe.txt with the current table data
    try (BufferedWriter bw = new BufferedWriter(new FileWriter("ppe.txt"))) {
        for (int i = 0; i < model.getRowCount(); i++) {
            String itemCode = (String) model.getValueAt(i, 0); // Assuming item code is in the 1st column
            String quantity = (String) model.getValueAt(i, 1); // Assuming quantity is in the 2nd column
            String supplierCode = (String) model.getValueAt(i, 2); // Assuming supply code is in the 3rd column

            // Write each row to the file in the specified format
            bw.write(itemCode + " " + quantity + " " + supplierCode);
            bw.newLine(); // Move to the next line
        }
        suppButton.setEnabled(true);
        backButton.setEnabled(true);
        JOptionPane.showMessageDialog(rootPane, "Data saved successfully to ppe.txt.");
    } catch (IOException ex) {
        Logger.getLogger(AdminPPEInventory.class.getName()).log(Level.SEVERE, null, ex);
        JOptionPane.showMessageDialog(rootPane, "An error occurred while saving the file. Please try again.");
    }

    }//GEN-LAST:event_saveButtonActionPerformed

    private void suppButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_suppButtonActionPerformed
        
        
        suppButton.setEnabled(false);
        ArrayList<String> suppliercodes = new ArrayList<>();
        ArrayList<String> supplierCodesList = new ArrayList<>();
        String SUPcode;

        try {
            BufferedReader br = new BufferedReader(new FileReader("ppe.txt"));
            String record = br.readLine();

            while (record != null) {
                StringTokenizer token = new StringTokenizer(record, " ");

                while (token.hasMoreTokens()) {
                    suppliercodes.add(token.nextToken());

                    // After collecting 3 tokens, extract the supplier code
                    if (suppliercodes.size() == 3) {
                        SUPcode = suppliercodes.get(2); // Extract the supplier code (3rd token)

                        // Check if it's not already in the list (to keep unique codes)
                        if (!supplierCodesList.contains(SUPcode)) {
                            supplierCodesList.add(SUPcode);
                        }

                        suppliercodes.clear(); // Clear the temp list for the next set of tokens
                    }
                }
                record = br.readLine(); // Read the next line
            }

            // Writing unique supplier codes to suppliers.txt
            BufferedWriter bw = new BufferedWriter(new FileWriter("suppliers.txt"));
            for (String code : supplierCodesList) {
                bw.write(code);
                bw.newLine(); // Add a new line for each code
            }
            bw.close(); // Close BufferedWriter
            JOptionPane.showMessageDialog(rootPane, "Created Suppliers.txt file successfully");

        } catch (IOException ex) {
            JOptionPane.showMessageDialog(rootPane, "Error creating suppliers.txt file");
        }

        
    }//GEN-LAST:event_suppButtonActionPerformed

    
    
    
